# Session signing secret. Optional — if unset, the PIN pepper (from data/pin.json) is used.
# Generate a secure value: openssl rand -hex 32
# CORTEX_SESSION_SECRET=

# Session timeout in seconds (60–604800). Defaults to 28800 (8 hours).
# This can also be configured during onboarding and is stored in data/pin.json.
# CORTEX_SESSION_TTL_SECONDS=28800

# Required only for autonomous git commit and GitHub PR features.
# GH_TOKEN=
# GH_REPO=owner/repo

# Required for the ngrok sidecar in docker-compose.yml.
# Create an account and token at https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=
