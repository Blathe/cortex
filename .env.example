# CORTEX_SETUP_SECRET is required for the first-time token generation when the
# server has no stored auth token. Without it, the bootstrap endpoint is open to
# the first requester. Set this before starting the server on a shared machine.
# Generate a secure value: openssl rand -hex 32
# CORTEX_SETUP_SECRET=

# Encrypts the stored auth token at rest (agent/config/auth.json).
# Required in production. If unset in local development, plaintext fallback is used.
# Generate a secure value: openssl rand -hex 32
# CORTEX_TOKEN_ENCRYPTION_KEY=

# Required only for autonomous git commit and GitHub PR features.
# GH_TOKEN=
# GH_REPO=owner/repo

# Required for the ngrok sidecar in docker-compose.yml.
# Create an account and token at https://dashboard.ngrok.com/get-started/your-authtoken
# NGROK_AUTHTOKEN=
